#!/bin/sh

# Block commits that introduce destructive file operations
# Scan staged diff for rm / shutil.rmtree / os.remove / os.unlink / Path.unlink / Path.rmdir / shutil.rmdir
PATTERNS='\brm\s|shutil\.rmtree|os\.remove\(|os\.unlink\(|Path\.unlink\(|Path\.rmdir\(|shutil\.rmdir\('

if git diff --cached -U0 | grep -qE "$PATTERNS"; then
    echo "❌ Commit blocked: detected a destructive file operation in the diff."
    echo "   Matched patterns: rm, shutil.rmtree, os.remove, os.unlink, Path.unlink, Path.rmdir, shutil.rmdir"
    echo "   Use a temporary file outside the repo (/tmp/) and delete it manually when done."
    exit 1
fi
